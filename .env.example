# ─── Discord ──────────────────────────────────────────────────────────────────
# Получить токен: https://discord.com/developers/applications → "Bot" → "Reset Token"
# Включить в Bot settings: Message Content Intent, Server Members Intent
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# ID голосового канала, в который бот заходит автоматически (опционально)
# Включи Developer Mode в Discord, ПКМ по каналу → Copy Channel ID
AUTO_JOIN_CHANNEL=000000000000000000

# ID текстового канала для команд (опционально)
TEXT_CHANNEL=000000000000000000


# ─── Anthropic Claude (LLM) ───────────────────────────────────────────────────
# Получить: https://console.anthropic.com/settings/keys
# Нужен баланс минимум $5: https://console.anthropic.com/settings/billing
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE


# ─── Yandex SpeechKit (TTS) ───────────────────────────────────────────────────
# Получить:
#   1. Зайди на https://console.cloud.yandex.ru/
#   2. Создай сервисный аккаунт с ролью ai.speechkit-tts.user
#   3. Создай для него API-ключ
YANDEX_API_KEY=AQVN_YOUR_KEY_HERE
